APP_NAME=Call Center Analytics Agent
APP_ENV=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://callcenter:callcenter@localhost:5432/callcenter
DATABASE_READONLY_URL=postgresql+psycopg://callcenter_readonly:callcenter_readonly@localhost:5432/callcenter
SQL_MAX_LIMIT=1000
SQL_DEFAULT_LIMIT=100

LLM_PROVIDER=mock
LLM_MODEL=mock:offline
OPENAI_API_KEY=
GEMINI_API_KEY=

MEMORY_WINDOW_SIZE=6
MEMORY_COMPACTION_RATIO=0.70
MEMORY_SUMMARY_RATIO=0.70
